{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // empty'); case \"$cmd\" in *--no-verify*) printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"git --no-verify est bloque par politique projet\"}}' ;; esac"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "pnpm fix --skip=correctness/noUnusedImports",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm check-types",
            "async": true,
            "statusMessage": "Vérification des types…",
            "timeout": 180
          },
          {
            "type": "command",
            "command": "pnpm test",
            "async": true,
            "statusMessage": "Tests…",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
